# ----------------------------------------------------------------------
# Build output & Go specific
# ----------------------------------------------------------------------
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# ----------------------------------------------------------------------
# Local Development & IDEs
# ----------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ----------------------------------------------------------------------
# OS generated files
# ----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----------------------------------------------------------------------
# Terraform
# ----------------------------------------------------------------------
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ----------------------------------------------------------------------
# Secrets, Configs, and Databases
# ----------------------------------------------------------------------
# Environment files
.env
.env.*
!.env.example

# Sensitive keys and certificates
*.pem
*.pfx
*.p12
*.key
*.cert
*.crt

# Local databases
*.db
*.sqlite
*.sqlite3

# Configurations
configs/tfdriftctl.yaml
configs/*.local.yaml
